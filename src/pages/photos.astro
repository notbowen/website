---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import BackToHome from "@components/BackToHome.astro";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { PHOTOS } from "@consts";

const photos = (await getCollection("photos")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const countries = Array.from(
    new Set(photos.map((photo) => photo.data.country)),
).sort((a, b) => a.localeCompare(b));
---

<PageLayout title={PHOTOS.TITLE} description={PHOTOS.DESCRIPTION}>
    <Container>
        <div class="space-y-8">
            <BackToHome> Back </BackToHome>

            <div class="animate">
                <div class="space-y-3 pt-6">
                    <h1 class="text-2xl font-semibold text-black dark:text-white">
                        Photos
                    </h1>
                    <p class="max-w-screen-sm font-serif">
                        Photographs from trips, detours, and whatever else
                        happened to be worth pointing a camera at.
                    </p>
                </div>
            </div>

            <section class="animate space-y-4" aria-labelledby="country-filter">
                <h2 id="country-filter" class="sr-only">Filter photos by country</h2>
                <div
                    class="flex flex-wrap items-center justify-between gap-x-4 gap-y-3"
                    data-photo-filter
                >
                    <div class="flex flex-wrap gap-2">
                        <button
                            type="button"
                            class="country-filter rounded-sm border border-black/15 px-3 py-1.5 text-sm transition hover:border-black/30 hover:text-black aria-pressed:bg-black aria-pressed:text-white dark:border-white/20 dark:hover:border-white/40 dark:hover:text-white dark:aria-pressed:bg-white dark:aria-pressed:text-black"
                            data-filter-country="all"
                            aria-pressed="true"
                        >
                            All
                        </button>
                        {
                            countries.map((country) => (
                                <button
                                    type="button"
                                    class="country-filter rounded-sm border border-black/15 px-3 py-1.5 text-sm transition hover:border-black/30 hover:text-black aria-pressed:bg-black aria-pressed:text-white dark:border-white/20 dark:hover:border-white/40 dark:hover:text-white dark:aria-pressed:bg-white dark:aria-pressed:text-black"
                                    data-filter-country={country}
                                    aria-pressed="false"
                                >
                                    {country}
                                </button>
                            ))
                        }
                    </div>
                    <p class="text-sm opacity-75" data-photo-count>
                        {photos.length} photos
                    </p>
                </div>

                <ul class="grid gap-3 sm:grid-cols-2">
                    {
                        photos.map((photo) => (
                            <li
                                class="group space-y-1"
                                data-photo-card
                                data-country={photo.data.country}
                            >
                                <button
                                    type="button"
                                    class="block w-full text-left"
                                    data-photo-trigger
                                    data-photo-location={photo.data.location}
                                    data-photo-city={photo.data.city}
                                    data-photo-country={photo.data.country}
                                    aria-label={`View larger photo: ${photo.data.location}, ${photo.data.city}`}
                                >
                                    <Image
                                        src={photo.data.src}
                                        alt={`${photo.data.location}, ${photo.data.city}`}
                                        class="w-full rounded-lg border border-black/15 shadow-sm transition duration-300 group-hover:border-black/30 group-hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black dark:border-white/20 dark:group-hover:border-white/40 dark:focus-visible:outline-white"
                                    />
                                </button>
                                <div class="space-y-0">
                                    <span class="text-sm font-semibold text-black dark:text-white">
                                        {photo.data.location}
                                    </span>
                                    <div class="text-xs opacity-75">
                                        {photo.data.city}, {photo.data.country}
                                    </div>
                                </div>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </div>
    </Container>

    <dialog
        class="w-[calc(100vw-2rem)] max-w-4xl rounded-lg border border-black/15 bg-stone-100 p-0 text-black/70 shadow-2xl backdrop:bg-black/70 dark:border-white/20 dark:bg-stone-900 dark:text-white/75"
        data-photo-dialog
        aria-labelledby="photo-dialog-title"
    >
        <div class="relative overflow-hidden">
            <button
                type="button"
                class="absolute right-3 top-3 z-10 flex size-8 items-center justify-center rounded-sm bg-black/65 text-white transition hover:bg-black/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
                data-photo-dialog-close
                aria-label="Close photo popup"
            >
                <Icon name="material-symbols:close" class="size-5" />
            </button>
            <div class="bg-black px-0 pt-0">
                <img
                    class="mx-auto max-h-[80vh] w-full object-contain"
                    data-photo-dialog-image
                    alt=""
                />
            </div>
            <div class="bg-stone-100 px-4 py-3 dark:bg-stone-900">
                <h2
                    class="text-sm font-semibold text-black dark:text-white"
                    id="photo-dialog-title"
                    data-photo-dialog-location
                >
                </h2>
                <div class="text-xs opacity-75" data-photo-dialog-place></div>
            </div>
        </div>
    </dialog>
</PageLayout>

<script is:inline data-astro-rerun>
    function initPhotoFilters() {
        const root = document.querySelector("[data-photo-filter]");
        if (!root || root.dataset.photoFilterInitialized === "true") return;

        root.dataset.photoFilterInitialized = "true";

        const buttons = Array.from(
            root.querySelectorAll("[data-filter-country]"),
        );
        const cards = Array.from(document.querySelectorAll("[data-photo-card]"));
        const count = document.querySelector("[data-photo-count]");
        const validCountries = new Set(
            buttons.map((button) => button.dataset.filterCountry),
        );
        const params = new URLSearchParams(window.location.search);
        const requestedCountry = params.get("country");
        const initialCountry =
            requestedCountry && validCountries.has(requestedCountry)
                ? requestedCountry
                : "all";

        function photoLabel(total) {
            return total === 1 ? "photo" : "photos";
        }

        function applyFilter(country, updateUrl = true) {
            const activeCountry = validCountries.has(country) ? country : "all";
            let visible = 0;

            cards.forEach((card) => {
                const show =
                    activeCountry === "all" ||
                    card.dataset.country === activeCountry;
                card.hidden = !show;
                if (show) visible += 1;
            });

            buttons.forEach((button) => {
                button.setAttribute(
                    "aria-pressed",
                    String(button.dataset.filterCountry === activeCountry),
                );
            });

            if (count) {
                count.textContent =
                    activeCountry === "all"
                        ? `${cards.length} ${photoLabel(cards.length)}`
                        : `${visible} of ${cards.length} ${photoLabel(cards.length)}`;
            }

            if (!updateUrl) return;

            const nextUrl = new URL(window.location.href);
            if (activeCountry === "all") {
                nextUrl.searchParams.delete("country");
            } else {
                nextUrl.searchParams.set("country", activeCountry);
            }
            window.history.replaceState({}, "", nextUrl);
        }

        buttons.forEach((button) => {
            button.addEventListener("click", () => {
                applyFilter(button.dataset.filterCountry);
            });
        });

        applyFilter(initialCountry, false);
    }

    function initPhotoDialog() {
        const dialog = document.querySelector("[data-photo-dialog]");
        if (!dialog || dialog.dataset.photoDialogInitialized === "true") return;

        dialog.dataset.photoDialogInitialized = "true";

        const image = dialog.querySelector("[data-photo-dialog-image]");
        const location = dialog.querySelector("[data-photo-dialog-location]");
        const place = dialog.querySelector("[data-photo-dialog-place]");
        const closeButton = dialog.querySelector("[data-photo-dialog-close]");

        function setText(element, value) {
            if (element) element.textContent = value || "";
        }

        function openPhoto(trigger) {
            const cardImage = trigger.querySelector("img");
            if (!cardImage || !image) return;

            image.src = cardImage.currentSrc || cardImage.src;
            image.srcset = cardImage.srcset;
            image.sizes = cardImage.sizes;
            image.alt = cardImage.alt;
            setText(location, trigger.dataset.photoLocation);
            setText(
                place,
                [trigger.dataset.photoCity, trigger.dataset.photoCountry]
                    .filter(Boolean)
                    .join(", "),
            );

            if (typeof dialog.showModal === "function") {
                dialog.showModal();
            } else {
                dialog.setAttribute("open", "");
            }
        }

        document.querySelectorAll("[data-photo-trigger]").forEach((trigger) => {
            trigger.addEventListener("click", () => openPhoto(trigger));
        });

        closeButton?.addEventListener("click", () => dialog.close());
        dialog.addEventListener("click", (event) => {
            if (event.target === dialog) dialog.close();
        });
    }

    document.addEventListener("DOMContentLoaded", initPhotoFilters);
    document.addEventListener("DOMContentLoaded", initPhotoDialog);
    document.addEventListener("astro:after-swap", initPhotoFilters);
    document.addEventListener("astro:after-swap", initPhotoDialog);
    initPhotoFilters();
    initPhotoDialog();
</script>
